# Supabase — from your project's Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Anthropic — one key shared by all users
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Admin emails (comma-separated) — these users get the 'admin' role on first login
ADMIN_EMAILS=your@email.com,another@email.com

# Server
PORT=3000

# File storage and editing
APP_URL=https://your-app-url.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_FOLDER_ID=optional-folder-id

# Storage provider — supabase (default), local, or s3
STORAGE_PROVIDER=supabase

# Local filesystem storage (STORAGE_PROVIDER=local)
STORAGE_LOCAL_PATH=/data/memex/documents

# S3-compatible storage (STORAGE_PROVIDER=s3)
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO, DigitalOcean Spaces
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
# Custom endpoint — omit for AWS, set for R2/B2/MinIO/etc.
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=false
