# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string (standalone deployment)
DATABASE_URL=postgres://memex:changeme@localhost:5432/memex

# ── Auth — Keycloak ───────────────────────────────────────────────────────────
# Public URL the browser redirects to for login (must be reachable by users)
KEYCLOAK_URL=http://localhost:8080
# Internal URL for server-to-server JWKS verification (omit if same as above)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=memex
KEYCLOAK_CLIENT_ID=memex-app

# ── Keycloak admin (docker-compose only) ─────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
POSTGRES_PASSWORD=changeme

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Admin emails ──────────────────────────────────────────────────────────────
# Comma-separated; these users get the 'admin' role on first login
ADMIN_EMAILS=your@email.com,another@email.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── File storage and editing ──────────────────────────────────────────────────
APP_URL=https://your-app-url.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_FOLDER_ID=optional-folder-id

# Storage provider — local (default), s3, or supabase
STORAGE_PROVIDER=local

# Local filesystem storage (STORAGE_PROVIDER=local)
STORAGE_LOCAL_PATH=/data/memex/documents

# S3-compatible storage (STORAGE_PROVIDER=s3)
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO, DigitalOcean Spaces
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
# Custom endpoint — omit for AWS, set for R2/B2/MinIO/etc.
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=false

# Supabase storage (STORAGE_PROVIDER=supabase — legacy / Supabase-hosted deployments only)
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── At-rest encryption (local storage only) ───────────────────────────────────
# AES-256-GCM. Provide a 64-char hex key or any passphrase.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configurable from the admin panel — no restart required.
# WARNING: losing this key makes all encrypted files unrecoverable.
# STORAGE_ENCRYPTION_KEY=

# ── Network ──────────────────────────────────────────────────────────────────
# Reverse proxy trust (1 = one hop; loopback; linklocal; true = all — not recommended)
# TRUST_PROXY=1
# CORS_ORIGINS=https://app.yourco.com,https://admin.yourco.com
# MAX_UPLOAD_MB=50
# HTTP_PROXY=http://proxy.company.com:8080
# BIND_ADDRESS=0.0.0.0

# -- Rate limiting ------------------------------------------------------------
# Set RATE_LIMIT_ENABLED=false only for trusted internal testing.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_API_MAX=300
# RATE_LIMIT_AUTH_MAX=20
